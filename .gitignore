################################################################################
# Data files (keep small tracked examples)
################################################################################
# Ignore raw input traces by default (often large)
data/traces.csv

# If you introduce new local data exports, ignore them…
data/**/*.csv
data/**/*.tsv

# …but keep the repo's example outputs currently tracked (if desired)
!data/annotations.csv
!data/predictions.csv
